{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python Debugger: Current File with Arguments",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal",
      "args": "${command:pickArgs}"
    },
    {
      "name": "Python: 带参数调试 main.py",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/expense_tracker/main.py",
      //"args": ["add", "28.5", "餐饮", "--desc", "午饭"],
      // "args": ["list"],
      "args": ["summary"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}/expense_tracker"
    }
  ]
}